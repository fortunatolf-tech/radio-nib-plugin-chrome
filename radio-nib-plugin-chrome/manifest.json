{
  "manifest_version": 3,
  "name": "Rádio NIB — Mini Player",
  "short_name": "Rádio NIB",
  "version": "1.0.0",
  "description": "Mini player da Rádio NIB (Nerds in Black): play/pause, mudo, volume e o nome da música ao vivo.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rádio NIB — Mini Player",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "offscreen"],
  "host_permissions": ["https://radio.nerdsinblack.com.br/*"]
}
